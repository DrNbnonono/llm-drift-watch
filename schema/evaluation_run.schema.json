{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QuestionBankEvaluationRun",
  "type": "object",
  "required": [
    "run_id",
    "started_at",
    "provider_id",
    "model_alias",
    "model_name",
    "base_url",
    "bank_version",
    "status",
    "totals",
    "execution_status",
    "run_kind",
    "progress"
  ],
  "properties": {
    "run_id": {
      "type": "string"
    },
    "started_at": {
      "type": "string"
    },
    "finished_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "provider_id": {
      "type": "string"
    },
    "model_alias": {
      "type": "string"
    },
    "model_name": {
      "type": "string"
    },
    "base_url": {
      "type": "string"
    },
    "bank_version": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "running",
        "completed",
        "failed"
      ]
    },
    "execution_status": {
      "type": "string",
      "enum": [
        "queued",
        "running",
        "completed",
        "failed",
        "cancelled"
      ]
    },
    "run_kind": {
      "type": "string",
      "enum": [
        "base",
        "retry"
      ]
    },
    "parent_run_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "retry_policy": {
      "type": [
        "string",
        "null"
      ]
    },
    "config": {
      "type": "object"
    },
    "progress": {
      "type": "object",
      "required": [
        "items_total",
        "items_completed",
        "items_failed",
        "items_inflight"
      ],
      "properties": {
        "items_total": {
          "type": "integer"
        },
        "items_completed": {
          "type": "integer"
        },
        "items_failed": {
          "type": "integer"
        },
        "items_inflight": {
          "type": "integer"
        }
      }
    },
    "totals": {
      "type": "object",
      "required": [
        "items_total",
        "items_completed",
        "items_failed"
      ],
      "properties": {
        "items_total": {
          "type": "integer"
        },
        "items_completed": {
          "type": "integer"
        },
        "items_failed": {
          "type": "integer"
        }
      }
    },
    "summary_metrics": {
      "type": "object"
    },
    "report_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "canonical_summary_path": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
