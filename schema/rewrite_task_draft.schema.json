{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "QuestionBankRewriteDraft",
  "type": "object",
  "required": [
    "rewrite_id",
    "source_candidate_ids",
    "target_module",
    "target_subtype",
    "rewrite_strategies",
    "draft_status",
    "scoring_method",
    "direct_public_reuse",
    "contamination_risk"
  ],
  "properties": {
    "rewrite_id": {
      "type": "string"
    },
    "source_candidate_ids": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "source_names": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "target_module": {
      "type": "string"
    },
    "target_subtype": {
      "type": "string"
    },
    "item_format": {
      "type": "string",
      "enum": [
        "single_turn",
        "multi_turn_group"
      ]
    },
    "rewrite_strategies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "surface_rewrite",
          "parameter_swap",
          "context_reframe",
          "option_rebuild",
          "constraint_recomposition",
          "turn_expansion",
          "candidate_fusion",
          "fresh_source_swap"
        ]
      }
    },
    "draft_prompt": {
      "type": [
        "string",
        "null"
      ]
    },
    "draft_turns": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "object",
        "required": [
          "role",
          "content"
        ],
        "properties": {
          "role": {
            "type": "string",
            "enum": [
              "system",
              "user",
              "assistant"
            ]
          },
          "content": {
            "type": "string"
          }
        }
      }
    },
    "draft_answer": {
      "type": [
        "string",
        "number",
        "null"
      ]
    },
    "draft_options": {
      "type": [
        "array",
        "null"
      ],
      "items": {
        "type": "string"
      }
    },
    "scoring_method": {
      "type": "string"
    },
    "scoring_params": {
      "type": "object"
    },
    "draft_status": {
      "type": "string",
      "enum": [
        "pending",
        "rewritten",
        "reviewed",
        "accepted",
        "rejected"
      ]
    },
    "direct_public_reuse": {
      "type": "boolean"
    },
    "contamination_risk": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "similarity_controls": {
      "type": "object",
      "properties": {
        "lexical_overlap_max": {
          "type": [
            "number",
            "null"
          ]
        },
        "preserve_answer_type_only": {
          "type": [
            "boolean",
            "null"
          ]
        },
        "notes": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "review_notes": {
      "type": "string"
    }
  }
}
